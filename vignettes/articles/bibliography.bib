@article{pereira_exploring_2023,
  title = {Exploring the Time Geography of Public Transport Networks with the Gtfs2gps Package},
  author = {Pereira, Rafael H. M. and Andrade, Pedro R. and Vieira, Jo{\~a}o Pedro Bazzo},
  year = 2023,
  month = jul,
  journal = {Journal of Geographical Systems},
  volume = {25},
  number = {3},
  pages = {453--466},
  issn = {1435-5949},
  doi = {10.1007/s10109-022-00400-x},
  urldate = {2026-05-27},
  abstract = {The creation of the General Transit Feed Specification (GTFS) in the mid-2000s provided a new data format for cities to organize and share digital information on their public transport systems. GTFS feeds store geolocated data on public transport networks, including information on routes, stops, timetables, and service levels. The GTFS standard is now widely adopted by thousands of transport authorities and a wide variety of software applications for different purposes, including trip planning, timetable creation and accessibility analysis. Yet, there is still a lack of tools to parse GTFS data when the objective is to analyze the complex spatial and temporal patterns of public transport systems. This paper presents \textbraceleft gtfs2gps\textbraceright, a new general-purpose computational tool to easily process static GTFS data that allows one to analyze the space--time trajectories of public transport vehicles at fine spatial and temporal resolutions. \textbraceleft gtfs2gps\textbraceright{} is an open-source R package that employs parallel computing to convert GTFS feeds from relational text files into a trajectory data table, similar to GPS records, with the timestamps of vehicles in every trip. This paper explains the package functionalities and demonstrates how \textbraceleft gtfs2gps\textbraceright{} can be used to articulate key concepts in time geography to explore and visualize the spatial and temporal patterns of public transport networks. We also present a case study looking at how \textbraceleft gtfs2gps\textbraceright{} can be used to examine socioeconomic and spatial--temporal inequalities in access to public transport, providing key information to monitor cities' progress toward the Sustainable Development Goals. The paper is accompanied by a computational notebook in R Markdown to support reproducibility of the results in this paper and to replicate the analysis for other contexts where GTFS data are available. Given the widespread use of GTFS, \textbraceleft gtfs2gps\textbraceright{} opens new possibilities for researchers to examine the time geography of public transport systems in urban areas across the globe.},
  langid = {english},
  keywords = {GTFS,gtfs2gps,L90,Public transport,R40,Time geography,Transport networks}
}

@article{reynolds_social_2025,
  title = {Social Needs and Gaps in Transit Service: {{New GTFS}} Tools \& Updates to 2021 Data},
  author = {Reynolds, James and Currie, Graham and Qu, Yanda},
  year = 2025,
  abstract = {Public transport often provides mobility to those who cannot drive themselves or who otherwise lack access to motorised transport. Hence, social equity perspectives on policymaking might suggest directing resources towards where those with greater needs live. Along these lines Currie (2010) presented a method for identifying locations with very high social needs for transport but little or no transit supply, and used it to assess needs-gaps in Greater Melbourne in 2006. However, undertaking similar assessments elsewhere may have been challenging at the time due to the need to process large amounts of timetable data. General Transit Feed Specification (GTFS) datasets are now provided by many operators. As of yet there are no known tools for using this data in social needs-gaps analysis as per the Currie (2010) approach. This paper reports the development of an R package with such tools, and results for Melbourne in 2016 and 2021 for comparison with those from 2006. Results indicate a 140\% increase in the number of residents living in areas with Very High needs but Very Low or Zero transit supply (139,004 in 2006 to 333,887 in 2021), compared to only 46\% population growth (3.4 to 4.9m). This means the share of Greater Melbourne's residents living in areas with the largest needs-gaps has increased (4.2\% to 6.8\%). The paper also briefly revisits a case study of an early-2010s development in the outer south-east suburbs, reported in Delbosc et al. (2015), finding positive changes in service level at this local scale, but that needs-gaps and lack of services remain a challenge. While Melbourne may be an outlier in terms of population growth and (low) density, these results suggest that those most in need may be continuing to receive only limited transit supply. Directions for further research and limitations are also identified.},
  langid = {english},
  file = {/Users/mwbc/Zotero/storage/86B4HQPZ/Reynolds et al. - 2025 - Social needs and gaps in transit service New GTFS tools & updates to 2021 data.pdf}
}
